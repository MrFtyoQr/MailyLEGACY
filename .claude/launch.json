{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Expo App (MailyLEGACY)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start"],
      "cwd": "MailyLEGACYapp",
      "port": 8081
    },
    {
      "name": "Admin Portal (Next.js)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "admin-portal",
      "port": 3000
    },
    {
      "name": "Django Backend",
      "runtimeExecutable": "python",
      "runtimeArgs": ["manage.py", "runserver", "0.0.0.0:8000"],
      "cwd": "mailytcuida_backend",
      "port": 8000
    }
  ]
}
